<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MapStylingDialog</class>
 <widget class="QDialog" name="MapStylingDialog">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>600</width>
    <height>860</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>고고학 도면 시각화 도구 (Map Styler) - ArchToolkit</string>
  </property>
  <layout class="QVBoxLayout" name="verticalLayout">
   <item>
    <widget class="QLabel" name="lblHeader">
     <property name="text">
      <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-size:10pt; font-weight:600;&quot;&gt;전문가용 지도 스타일링&lt;/span&gt;&lt;/p&gt;&lt;p&gt;벡터 데이터(도로, 수계, 건물)를 고고학 도면 표준으로 시각화하고,&lt;br/&gt;배경 지형(DEM)에 음영기복(Hillshade) 효과를 적용합니다.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
     </property>
     <property name="styleSheet">
      <string>background-color: #fce4ec; padding: 10px; border-radius: 4px; border: 1px solid #f8bbd0;</string>
     </property>
    </widget>
   </item>
   <item>
    <widget class="QGroupBox" name="groupLayerSelect">
     <property name="title">
      <string>1. 스타일을 적용할 원본 레이어 선택</string>
     </property>
     <layout class="QVBoxLayout" name="verticalLayout_2">
      <item>
       <widget class="QListWidget" name="lstLayers">
        <property name="minimumSize">
         <size>
          <width>0</width>
          <height>200</height>
         </size>
        </property>
        <property name="alternatingRowColors">
         <bool>true</bool>
        </property>
       </widget>
      </item>
      <item>
       <layout class="QHBoxLayout" name="horizontalLayout">
        <item>
         <widget class="QPushButton" name="btnSelectAll">
          <property name="text">
           <string>모두 선택</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QPushButton" name="btnDeselectAll">
          <property name="text">
           <string>선택 해제</string>
          </property>
         </widget>
        </item>
        <item>
         <spacer name="horizontalSpacer">
          <property name="orientation">
           <enum>Qt::Horizontal</enum>
          </property>
         </spacer>
        </item>
       </layout>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="QGroupBox" name="groupVectorStyle">
     <property name="title">
      <string>2. 벡터 데이터 스타일링 옵션</string>
     </property>
     <layout class="QVBoxLayout" name="verticalLayout_3">
      <item>
       <widget class="QCheckBox" name="chkRoads">
        <property name="text">
         <string>🛣️ 도로 (Roads): 등급별(고속/국도/지방도) 선폭 및 색상 적용</string>
        </property>
        <property name="checked">
         <bool>true</bool>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QCheckBox" name="chkRivers">
        <property name="text">
         <string>💧 하천/수계 (Rivers): 유역 규모에 따른 위계 표현</string>
        </property>
        <property name="checked">
         <bool>true</bool>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QCheckBox" name="chkBuildings">
        <property name="text">
         <string>🏠 건물 (Buildings): 입체감 부여 및 그림자 효과</string>
        </property>
        <property name="checked">
         <bool>true</bool>
        </property>
       </widget>
      </item>
      <item>
       <layout class="QHBoxLayout" name="horizontalLayout_Shadow">
        <item>
         <spacer name="horizontalSpacer_2">
          <property name="orientation">
           <enum>Qt::Horizontal</enum>
          </property>
          <property name="sizeHint" stdset="0">
           <size>
            <width>20</width>
            <height>20</height>
           </size>
          </property>
         </spacer>
        </item>
        <item>
         <widget class="QLabel" name="label_Shadow">
          <property name="text">
           <string>↳ 건물 그림자 오프셋 (깊이):</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QDoubleSpinBox" name="spinOffset">
          <property name="value">
           <double>0.5</double>
          </property>
          <property name="singleStep">
           <double>0.1</double>
          </property>
          <property name="suffix">
           <string> mm</string>
          </property>
         </widget>
        </item>
       </layout>
      </item>
     </layout>
    </widget>
   </item>
   <item>
   <widget class="QGroupBox" name="groupDemStyle">
     <property name="title">
      <string>3. 배경 지형 (DEM) 시각화</string>
     </property>
     <layout class="QVBoxLayout" name="verticalLayout_4">
      <item>
       <widget class="QCheckBox" name="chkDemStyling">
        <property name="text">
         <string>🏔️ 배경 지형 스타일링 적용 (음영기복 + 고도채색)</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QgsMapLayerComboBox" name="cmbDemLayer">
        <property name="enabled">
         <bool>true</bool>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="QGroupBox" name="groupPresetExport">
     <property name="title">
      <string>4. 프리셋/내보내기</string>
     </property>
     <layout class="QVBoxLayout" name="verticalLayout_PresetExport">
      <item>
       <layout class="QHBoxLayout" name="horizontalLayout_CodeConfig">
        <item>
         <widget class="QLabel" name="label_CodeConfig">
          <property name="text">
           <string>DXF 코드 매핑(JSON):</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QLabel" name="lblCodeConfigPath">
          <property name="text">
           <string>(자동)</string>
          </property>
          <property name="textInteractionFlags">
           <set>Qt::TextSelectableByKeyboard|Qt::TextSelectableByMouse</set>
          </property>
         </widget>
        </item>
       </layout>
      </item>
      <item>
       <layout class="QHBoxLayout" name="horizontalLayout_CodeButtons">
        <item>
         <widget class="QPushButton" name="btnOpenCodeConfig">
          <property name="text">
           <string>매핑 파일 열기</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QPushButton" name="btnReloadCodeConfig">
          <property name="text">
           <string>다시 불러오기</string>
          </property>
         </widget>
        </item>
        <item>
         <spacer name="horizontalSpacer_4">
          <property name="orientation">
           <enum>Qt::Horizontal</enum>
          </property>
         </spacer>
        </item>
       </layout>
      </item>
      <item>
       <widget class="QPushButton" name="btnExportPreset">
        <property name="text">
         <string>📦 QML/프리셋 내보내기...</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QLabel" name="lblPresetHint">
        <property name="text">
         <string>선택한 스타일(도로/하천/건물) QML과 현재 DXF 코드 매핑 JSON을 폴더로 저장합니다. (DEM 스타일은 DEM 선택+체크 시 함께 저장)</string>
        </property>
        <property name="wordWrap">
         <bool>true</bool>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <layout class="QHBoxLayout" name="horizontalLayout_Buttons">
     <item>
      <spacer name="horizontalSpacer_3">
       <property name="orientation">
        <enum>Qt::Horizontal</enum>
       </property>
      </spacer>
     </item>
     <item>
      <widget class="QPushButton" name="btnApply">
       <property name="text">
        <string>✨ 스타일 적용 (Apply Styling)</string>
       </property>
       <property name="styleSheet">
        <string>padding: 10px 20px; font-weight: bold; background-color: #ec407a; color: white; border-radius: 4px;</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QPushButton" name="btnClose">
       <property name="text">
        <string>닫기</string>
       </property>
      </widget>
     </item>
    </layout>
   </item>
  </layout>
 </widget>
 <customwidgets>
  <customwidget>
   <class>QgsMapLayerComboBox</class>
   <extends>QComboBox</extends>
   <header>qgis.gui</header>
  </customwidget>
 </customwidgets>
